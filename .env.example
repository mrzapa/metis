# METIS environment variables
# Copy to .env and fill in values for local development.

# --- API server ---------------------------------------------------------
# Bind host/port for the local API. Defaults: 127.0.0.1 / auto-assigned.
# METIS_API_HOST=127.0.0.1
# METIS_API_PORT=8000

# Bearer token required by all data endpoints when set. If unset, auth is
# disabled (intended only for single-user local dev).
# METIS_API_TOKEN=change-me

# --- Installer / launcher ----------------------------------------------
# Install location used by scripts/install_metis.{sh,ps1}.
# METIS_INSTALL_DIR=$HOME/.metis

# Python interpreter the installer should use.
# METIS_PYTHON=python3.12

# --- Test fixtures ------------------------------------------------------
# Live Weaviate parity audit (used by .github/workflows/ci.yml live job).
# METIS_TEST_WEAVIATE_URL=http://127.0.0.1:8080
# METIS_TEST_WEAVIATE_GRPC_HOST=127.0.0.1
# METIS_TEST_WEAVIATE_GRPC_PORT=50051
# METIS_TEST_WEAVIATE_GRPC_SECURE=false
