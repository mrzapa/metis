# METIS environment variables
# Copy to .env and fill in values for local development.

# --- API server ---------------------------------------------------------
# Bind host/port for the local API. Defaults: 127.0.0.1 / auto-assigned.
# METIS_API_HOST=127.0.0.1
# METIS_API_PORT=8000

# Bearer token required by all data endpoints when set. If unset, auth is
# disabled (intended only for single-user local dev).
# METIS_API_TOKEN=change-me

# Comma-separated list of origins allowed by CORS. Defaults to the Next.js
# dev server and Tauri origins. Set "*" to allow everything (dev only).
# METIS_API_CORS_ORIGINS=http://localhost:3000,tauri://localhost

# Persistence paths. Default under the platform user data dir.
# METIS_SESSION_DB_PATH=/path/to/sessions.db
# METIS_APP_STATE_DB_PATH=/path/to/app_state.db

# Gate for writing API keys through the settings endpoint. Set to "1" to
# allow; default is refuse.
# METIS_ALLOW_API_KEY_WRITE=0

# Override path for the Nyx component catalogue (JSON).
# METIS_NYX_CATALOG_PATH=/path/to/nyx_catalog.json

# --- Installer / launcher ----------------------------------------------
# Install location used by scripts/install_metis.{sh,ps1}.
# METIS_INSTALL_DIR=$HOME/.metis

# Python interpreter the installer should use.
# METIS_PYTHON=python3.12

# --- Audit / CI ---------------------------------------------------------
# Require live backends (Weaviate, etc.) during the parity audit. Set "1" in CI.
# METIS_PARITY_REQUIRE_LIVE_BACKENDS=0

# Live Weaviate parity audit (used by .github/workflows/ci.yml live job).
# METIS_TEST_WEAVIATE_URL=http://127.0.0.1:8080
# METIS_TEST_WEAVIATE_GRPC_HOST=127.0.0.1
# METIS_TEST_WEAVIATE_GRPC_PORT=50051
# METIS_TEST_WEAVIATE_GRPC_SECURE=false

# --- Web frontend (apps/metis-web) -------------------------------------
# Base URL the browser uses to reach the API. Must match the running API.
# NEXT_PUBLIC_METIS_API_BASE=http://127.0.0.1:8000

# Bearer token the browser sends; must match METIS_API_TOKEN above when set.
# NEXT_PUBLIC_METIS_API_TOKEN=change-me
