{
  "productName": "axiom-desktop",
  "version": "0.0.1",
  "identifier": "app.axiom.desktop",
  "build": {
    "beforeDevCommand": "cd ../axiom-web && pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cd ../axiom-web && pnpm build",
    "frontendDist": "../axiom-web/out"
  },
  "app": {
    "windows": [
      {
        "title": "Axiom Desktop (Experimental)",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
