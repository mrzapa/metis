      "registryDependencies": ["axiom-tokens"],
      "files": [
        {
          "path": "registry/base-nova/agentic-step-indicator/agentic-step-indicator.tsx",
          "type": "registry:component"
        }
      ]
    },
    {
      "name": "action-card",
      "type": "registry:component",
