      "dependencies": ["react-markdown"],
      "files": [
        {
          "path": "registry/base-nova/assistant-markdown/assistant-markdown.tsx",
          "type": "registry:component"
        }
      ]
    },
    {
      "name": "evidence-source-card",
      "type": "registry:component",
      "title": "Evidence Source Card",
