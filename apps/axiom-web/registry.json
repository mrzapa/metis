{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "axiom",
  "homepage": "https://github.com/mrzapa/axiom",
  "items": [
    {
      "name": "axiom-tokens",
      "type": "registry:style",
      "title": "Axiom Design Tokens",
      "description": "Shared design tokens (colors, radii, sidebar palette) for the Axiom design system. Provides light and dark mode variables in OKLch color space.",
