      "dependencies": ["lucide-react"],
      "files": [
        {
          "path": "registry/base-nova/action-card/action-card.tsx",
          "type": "registry:component"
        }
      ]
    },
    {
      "name": "assistant-markdown",
      "type": "registry:component",
      "title": "Assistant Markdown",
      "description": "Renders streamed LLM markdown responses with consistent typographic styling for prose, code blocks, and links.",
