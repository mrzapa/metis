{
  "productName": "METIS",
  "version": "1.0.0",
  "identifier": "app.metis.desktop",
  "build": {
    "beforeDevCommand": "cd ../metis-web && pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cd ../metis-web && pnpm build",
    "frontendDist": "../metis-web/out",
    "devtools": true
  },
  "app": {
    "windows": [
      {
        "title": "METIS",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "PLACEHOLDER — replace with output of `tauri signer generate` before shipping",
      "endpoints": [
        "https://PLACEHOLDER/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/metis-api"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
