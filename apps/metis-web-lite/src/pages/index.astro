---
import Shell from "../layouts/Shell.astro";
---

<Shell title="metis-web-lite">
  <h2 class="page-title">metis-web-lite</h2>
  <p class="page-subtitle">
    Minimal prototype for streaming RAG queries, session management, and settings
    against the local METIS API. Intentionally plain — not a design showcase.
  </p>

  <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
    <a href="/chat" class="btn">Open Chat</a>
    <a href="/sessions" class="btn btn-ghost">Sessions</a>
    <a href="/library" class="btn btn-ghost">Library</a>
    <a href="/settings" class="btn btn-ghost">Settings</a>
  </div>
</Shell>
